#!/usr/bin/env node

// @ts-check

import { PDFDocument } from 'pdf-lib';
import sharp from 'sharp';
import { readdir, writeFile } from 'fs/promises';
import { existsSync } from 'fs';
import { join, resolve, basename } from 'path';

/** Parse CLI args — folder is the first non-flag argument */
const args = process.argv.slice(2);
const compress = args.includes('--compress');
const folderArg = args.find(a => !a.startsWith('--'));
if (!folderArg) {
  console.error('Usage: create-pdf [--compress] <folder>');
  process.exit(1);
}

/** Resolve the target folder and its images/ subdirectory */
const folder = resolve(folderArg);
const imagesDir = join(folder, 'images');

if (!existsSync(imagesDir)) {
  console.error(`No "images" subfolder found in ${folder}`);
  process.exit(1);
}

/** Collect supported image files, sorted so page order is deterministic */
const files = (await readdir(imagesDir))
  .filter(f => /\.(tif|tiff|jpg|jpeg|png|webp)$/i.test(f))
  .sort();

if (!files.length) {
  console.error('No images found in images/');
  process.exit(1);
}

console.log(`Found ${files.length} images, building PDF (${compress ? 'lossy' : 'lossless'})...`);

const pdf = await PDFDocument.create();

for (const [i, file] of files.entries()) {
  process.stdout.write(`\r[${i + 1}/${files.length}] ${file}`);
  const imgPath = join(imagesDir, file);
  let img;
  if (!compress) {
    /** Lossless: convert to PNG via sharp, embed as-is */
    const buf = await sharp(imgPath).png().toBuffer();
    img = await pdf.embedPng(buf);
  } else {
    /** Lossy (--compress): convert to JPEG q80 for smaller output */
    const buf = await sharp(imgPath).jpeg({ quality: 80 }).toBuffer();
    img = await pdf.embedJpg(buf);
  }
  /** Each image gets its own page sized to the image dimensions */
  const page = pdf.addPage([img.width, img.height]);
  page.drawImage(img, { x: 0, y: 0, width: img.width, height: img.height });
}

process.stdout.write('\n');

/** Write the PDF next to the source folder, named after it */
const outName = basename(folder) + '.pdf';
const outPath = join(folder, '..', outName);
await writeFile(outPath, await pdf.save());
console.log(`Saved: ${outPath}`);
